# ─────────────────────────────────────────────────────────────
# GrayCON — .env.local
#
# ⚠️  THIS FILE IS IN .gitignore — NEVER COMMIT IT TO GITHUB
#
# SETUP INSTRUCTIONS:
#  1. Go to console.firebase.google.com
#  2. Open your project → Project Settings → Your apps
#  3. Copy the firebaseConfig object values
#  4. Paste them below replacing each "YOUR_..." placeholder
#  5. Save this file — build.js will inject these at build time
#
# FOR VERCEL PRODUCTION:
#  Add the same keys in Vercel Dashboard
#  → Settings → Environment Variables
#  (Vercel injects them securely during deployment)
# ─────────────────────────────────────────────────────────────

VITE_FIREBASE_API_KEY=YOUR_API_KEY_HERE
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT_ID.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID_HERE
VITE_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID_HERE
VITE_FIREBASE_APP_ID=YOUR_APP_ID_HERE
